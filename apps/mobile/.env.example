# DiviFlow 移动端环境变量示例
# 复制为 .env 后填写实际值（.env 不会提交到 Git）

# ─── 后端 API 地址 ───────────────────────────────────────
# 根据运行环境选一个：
#
# 1) iOS 模拟器：可直接用 localhost
#    EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
#
# 2) Android 模拟器：localhost 指向模拟器本机，需用 10.0.2.2 访问宿主机
#    EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
#
# 3) 真机（Expo Go / Dev Client）：需要 PC 和手机在同一局域网，填 PC 的 LAN IP
#    Mac: ifconfig | grep "inet " | grep -v 127.0.0.1
#    Win: ipconfig | findstr IPv4
#    Linux: hostname -I | awk '{print $1}'
#    EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# ─── 市场数据源（可选，示例） ────────────────────────────
EXPO_PUBLIC_MARKET_DATA_KEY=
