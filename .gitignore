# ============================================================
# DiviFlow 息流 — .gitignore
# 适配：React Native + Expo + TypeScript / Python + FastAPI
# ============================================================

# ─── 通用 ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
*.swo
*.bak
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.history/
*.orig

# ─── 环境变量（切勿提交密钥） ─────────────────────────────
.env
.env.*
!.env.example
!.env.template

# ─── Node / JavaScript / TypeScript ───────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.npm/
.yarn/cache
.yarn/install-state.gz
.yarn/unplugged
.yarn/build-state.yml

# 构建产物
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo

# ─── React Native / Expo ──────────────────────────────────
.expo/
.expo-shared/
web-build/
expo-env.d.ts

# iOS
ios/Pods/
ios/build/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
*.mobileprovision
*.p8
*.p12
*.key
*.ipa

# Android
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/captures/
android/local.properties
*.keystore
!debug.keystore
*.aab
*.apk

# Metro
.metro-health-check*

# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
pip-log.txt
pip-delete-this-directory.txt

# 虚拟环境
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Python 构建产物
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

# ─── 测试与覆盖率 ─────────────────────────────────────────
coverage/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.nox/
.cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
*.py,cover
junit.xml
test-results/

# ─── Linter / Formatter 缓存 ──────────────────────────────
.eslintcache
.stylelintcache
.prettiercache
.mypy_cache/
.ruff_cache/
.pytype/

# ─── 数据库 / 本地数据 ────────────────────────────────────
*.sqlite
*.sqlite3
*.db
local_data/
uploads/

# ─── AI 模型 / 大文件 ─────────────────────────────────────
*.pkl
*.bin
*.safetensors
# 仅忽略根目录 / ml-models 下的大模型文件，避免误伤后端 ORM 的 app/models/
/models/
/ml-models/
/checkpoints/

# ─── 其他 ────────────────────────────────────────────────
.serverless/
.vercel
.firebase/
*.pem
.aider*
